BOT_MODE=polling # or webhook
BOT_TOKEN=
LOG_LEVEL=debug
DEBUG=false
WEBHOOK_URL=webhook
WEBHOOK_SECRET_TOKEN=
PORT=3000
BOT_ADMINS=

# Network selector: testnet (default) | mainnet.
# NOTE: DeepBook Predict is testnet-only today; NETWORK=mainnet fails fast until its IDs exist.
NETWORK=testnet

# Sui Network Configuration
SUI_RPC_URL=https://fullnode.testnet.sui.io       # JSON-RPC — execution + DeepBook SDK (deprecated, sunset 2026-07-31)
SUI_GRPC_URL=https://fullnode.testnet.sui.io:443  # gRPC — reads + simulation (primary data path)
SUI_EXECUTE_TRANSPORT=grpc                        # grpc (default) | jsonrpc — transport for tx execution

# DeepBook Predict Configuration (Testnet)
PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
PREDICT_REGISTRY_ID=0x43af14fed5480c20ff77e2263d5f794c35b9fab7e2212903127062f4fe2a6e64
PREDICT_MANAGER_ID=

# dUSDC Configuration
DUSDC_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
DUSDC_CURRENCY_ID=0xf3000dff421833d4bb8ed58fac146d691a3aaba2785aa1989af65a7089ca3e9c
DUSDC_DECIMALS=6

# User Wallets (Custodial per-user)
# The bot generates one Sui wallet per Telegram user.
# Private keys are encrypted with the user's password and stored in SQLite.
# No global PRIVATE_KEY is required for per-user wallet signing.

# Predict Server
PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com

# AI Context (Optional)
ANTHROPIC_API_KEY=

# Frontend trade fee (broker commission) — OFF by default.
# Charged on the premium and routed to TREASURY_ADDRESS inside the mint PTB.
# To enable, set BOTH:
#   TRADE_FEE_BPS    — fee in basis points of the premium (100 = 1%); capped at 500 (5%).
#   TREASURY_ADDRESS — Sui address that receives the fee. Empty = no fee, whatever bps says.
TRADE_FEE_BPS=0
TREASURY_ADDRESS=

# Deployment
# SQLite file location. Local dev default: ./quick-predict.db.
# In Docker/Fly the volume is mounted at /data (set in Dockerfile/fly.toml).
DB_PATH=

# Litestream backups (VPS docker-compose path; see DEPLOY.md)
# e.g. s3://quickpredict-backups/db — works with S3, Backblaze B2, Cloudflare R2
LITESTREAM_REPLICA_URL=
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=