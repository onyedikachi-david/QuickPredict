    "@grammyjs/i18n": "^1.1.2",
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/parse-mode": "^2.3.0",
    "@grammyjs/ratelimiter": "^1.2.1",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@mysten/deepbook-v3": "^1.3.6",
    "@mysten/sui": "^2.16.3",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.42.0",
    "grammy-guard": "^0.5.0",
    "hono": "^4.12.18",
